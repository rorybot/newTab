{
  "name": "newtab",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Brave/Chrome new tab extension",
  "type": "module",
  "scripts": {
    "build": "esbuild src/newtab.ts --bundle --format=esm --target=chrome120 --outfile=newtab.js",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "watch": "esbuild src/newtab.ts --bundle --format=esm --target=chrome120 --outfile=newtab.js --watch"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.3"
  }
}
