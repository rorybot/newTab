{
  "manifest_version": 3,
  "name": "New Tab",
  "version": "0.1.14",
  "description": "Personal new tab — mortality clock, weather, Spotify, and whatever else I want.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://hacker-news.firebaseio.com/*",
    "https://news.ycombinator.com/*",
    "https://accounts.spotify.com/*",
    "https://api.spotify.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://127.0.0.1/*",
    "https://localhost/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["examples/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
