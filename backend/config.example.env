# Copy to config.env (gitignored) or export these vars before a one-shot scrape.

# --- weather feed (build_feeds.py) ---
# Fixed home location for the weather feed. The backend can't use browser
# geolocation like the extension does, so it needs its own coordinates here.
# Leave unset to skip building weather.json entirely (extension falls back
# to its own direct client-side fetch, same as when the backend isn't running).
# WEATHER_LAT=39.7392
# WEATHER_LON=-104.9903

# --- room scrape (scrape_room.py) ---
# scrape_room.py runs once, writes a snapshot JSON — not a live feed.

# Chatroom page URL (the page that contains shout-row-* table rows).
# Never commit a real private URL if you care about privacy.
ROOM_PAGE_URL=https://example.com/chatroom

# Optional: path to browser storage state (cookies) for logged-in scrapes.
# Create with: playwright codegen --save-storage=auth.json
# PLAYWRIGHT_STORAGE=auth.json

# Output JSON path (relative to backend/ or absolute)
# ROOM_OUT=out/room-feed.json
